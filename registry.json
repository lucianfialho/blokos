{
  "name": "blokos",
  "version": "1.0.0",
  "description": "Design System as Catalog — component registries with AI skills built-in",
  "framework": "react",
  "components": {
    "lesson-path": {
      "name": "lesson-path",
      "description": "Zigzag learning path component — displays a list of items in an alternating left/right layout connected by curved path connectors, inspired by Duolingo. Framework-agnostic: works with Next.js, Vite, or any React setup. Card content is fully customizable via renderCard render prop.",
      "category": "navigation",
      "files": [
        "components/lesson-path/lesson-path.tsx",
        "components/lesson-path/meta.json",
        "components/lesson-path/schema.ts"
      ],
      "schema": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Unique identifier for the item"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "locked",
                    "current",
                    "completed"
                  ],
                  "description": "Unlock state of the item"
                },
                "groupLabel": {
                  "type": "string",
                  "description": "Optional section label displayed above this item"
                }
              },
              "required": [
                "id",
                "status"
              ],
              "additionalProperties": false
            },
            "description": "List of items to display in the zigzag path"
          },
          "pathColor": {
            "type": "string",
            "description": "Color of the connector between cards (CSS color, default #1CB0F6)"
          },
          "className": {
            "type": "string",
            "description": "CSS class applied to the outer wrapper"
          }
        },
        "required": [
          "items"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "dependencies": [],
      "examples": [
        {
          "description": "Basic usage with image cards",
          "props": {
            "items": [
              {
                "id": "1",
                "status": "current",
                "groupLabel": "Beginner"
              },
              {
                "id": "2",
                "status": "locked"
              },
              {
                "id": "3",
                "status": "locked"
              }
            ],
            "pathColor": "#1CB0F6"
          }
        },
        {
          "description": "Bible series path",
          "props": {
            "items": [
              {
                "id": "genesis",
                "status": "completed",
                "groupLabel": "Old Testament"
              },
              {
                "id": "exodus",
                "status": "current"
              },
              {
                "id": "leviticus",
                "status": "locked"
              }
            ]
          }
        }
      ]
    }
  },
  "skill": "skill/blokos-skill.md"
}
